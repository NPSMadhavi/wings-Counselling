# Copy to apps/api/.env and fill in values.

# Admin auth
ADMIN_USERNAME=
ADMIN_PASSWORD=
JWT_SECRET=

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=wings
DB_PORT=3306

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=true
EMAIL_FROM=

# Frontend / candidate portal (used in interview booking email links)
NODE_ENV=development
# Origin only — do not include /candidate-portal or other paths.
CANDIDATE_PORTAL_URL=http://localhost:5173

# Production example:
# NODE_ENV=production
# CANDIDATE_PORTAL_URL=https://wings-counselling.org
